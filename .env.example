# --- Scraping ---
START_PAGE=1
END_PAGE=19
REQUEST_DELAY=1.5
BASE_URL=https://www.cyberpark.com.tr/firma-arsiv

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Sender info (used in generated emails) ---
SENDER_NAME=Ad Soyad
# basvurulan pozisyon / aday profili, orn: "Yazilim Muhendisi / Bilgisayar Muhendisligi mezunu"
SENDER_TITLE=
SENDER_COMPANY=
EMAIL_PURPOSE=

# --- Gmail send ---
GMAIL_SENDER=you@gmail.com
SEND_DELAY=2
# true birakirsan gercekten göndermez, sadece data/companies_sent_log.xlsx'e "DRY_RUN" olarak loglar
DRY_RUN=true

# CV dosyasi, proje klasorune (bu .env dosyasinin bulundugu klasor) gore relative yol.
# Dosya adinda bosluk olsa bile tirnak KULLANMADAN oldugu gibi yazilir.
CV_PATH=CV.pdf
